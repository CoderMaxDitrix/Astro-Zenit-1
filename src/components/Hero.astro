---
---
<section id="inicio" class="pt-32 pb-16 md:pt-40 md:pb-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center overflow-x-hidden">
    
    <div class="space-y-6">
        <span data-aos="fade-up" class="inline-block bg-amber-50 dark:bg-amber-950/30 text-primary font-bold text-[11px] px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors">
            Energía limpia para un futuro sostenible
        </span>
        
        <h1 data-aos="fade-up" data-aos-delay="100" class="text-[44px] md:text-[56px] font-extrabold text-dark dark:text-white leading-[1.15] tracking-tight transition-colors">
            Llevamos energía <br>
            <span class="text-primary">a donde la necesites</span>
        </h1>
        
        <p data-aos="fade-up" data-aos-delay="200" class="text-base md:text-lg text-gray-500 dark:text-gray-400 max-w-lg leading-relaxed transition-colors">
            En <strong class="text-dark dark:text-white">Zenit Solar</strong> ofrecemos soluciones fotovoltaicas integrales para hogares, comercios, industrias y el campo. 
            Diseñamos, instalamos y mantenemos sistemas de energía solar de alta eficiencia, ayudándote a reducir costos y cuidar el planeta.
        </p>
        
        <div data-aos="fade-up" data-aos-delay="300" class="flex flex-wrap gap-4 pt-2">
            <a href="#contacto" class="bg-primary text-white px-7 py-3.5 rounded-xl text-[15px] font-medium hover:bg-primary-hover flex items-center gap-2 transition-all shadow-md shadow-primary/20">
                Solicitar cotización <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
            <a href="#soluciones" class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 text-dark dark:text-white px-7 py-3.5 rounded-xl text-[15px] font-medium hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors shadow-sm">
                Conocé más
            </a>
        </div>
    </div>
    
    <div class="relative w-full max-w-lg mx-auto lg:max-w-none mt-8 lg:mt-0" data-aos="fade-left" data-aos-delay="200">
        <img src="https://images.unsplash.com/photo-1509391366360-2e959784a276?ixlib=rb-4.0.3&auto=format&fit=crop&w=900&q=80" 
             alt="Instalación de paneles solares" 
             class="rounded-[2rem] shadow-2xl w-full h-[500px] object-cover">
        
        <div class="absolute -top-6 -right-4 md:-right-8 z-10" data-aos="zoom-in" data-aos-delay="500">
            <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-xl p-3.5 flex items-center gap-3 animate-float">
                <div class="bg-amber-50 dark:bg-amber-950/40 p-2.5 rounded-full">
                    <i data-lucide="sun" class="w-5 h-5 text-primary"></i>
                </div>
                <div class="pr-2">
                    <p class="text-[13px] font-bold text-dark dark:text-white leading-tight">Energía Solar</p>
                    <p class="text-[11px] text-gray-500 dark:text-gray-400 leading-tight">100% renovable</p>
                </div>
            </div>
        </div>

        <div class="absolute bottom-12 -left-4 md:-left-12 z-10" data-aos="zoom-in" data-aos-delay="700">
            <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl shadow-xl p-4 flex items-center gap-3 animate-float-delayed">
                <div class="bg-orange-50 dark:bg-orange-950/30 p-3 rounded-full">
                    <i data-lucide="zap" class="w-6 h-6 text-primary"></i>
                </div>
                <div class="pr-2">
                    <p class="text-[14px] font-bold text-dark dark:text-white leading-tight">Ahorro garantizado</p>
                    <p class="text-[12px] text-gray-500 dark:text-gray-400 leading-tight mt-0.5">Hasta 80% en tu factura</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
        100% { transform: translateY(0px); }
    }
    .animate-float {
        animation: float 5s ease-in-out infinite;
    }
    .animate-float-delayed {
        animation: float 6s ease-in-out 2.5s infinite;
    }
</style>
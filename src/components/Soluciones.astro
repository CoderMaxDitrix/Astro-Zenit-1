<style>
    .soluciones-wrapper {
        background-color: #f8fafc;
        transition: background-color 0.3s, border-color 0.3s;
        padding: 5rem 0;
        border-top: 1px solid #e2e8f0;
    }
    :global(.dark) .soluciones-wrapper {
        background-color: #020618; 
        border-top-color: #0f172a;
    }
    .soluciones-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1rem;
    }
    @media (min-width: 768px) {
        .soluciones-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (min-width: 1024px) {
        .soluciones-grid { grid-template-columns: repeat(5, 1fr); }
    }

    /* Tarjetas Celular */
    .tarjeta-simple {
        background: white;
        border-radius: 1rem;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        cursor: pointer;
        transition: all 0.2s;
        aspect-ratio: 1/1;
    }
    :global(.dark) .tarjeta-simple {
        background: #090f26; 
        border-color: #1e293b;
    }
    .tarjeta-simple:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    }

    /* Renderizado de Tarjetas 3D */
    @media (min-width: 1024px) {
        .tarjeta-3d-wrapper { display: block; }
        .tarjeta-simple { display: none; }
        
        .container-3d {
            position: relative;
            width: 100%;
            aspect-ratio: 1 / 1;
            transition: 200ms;
            cursor: pointer;
        }
        .canvas-3d {
            perspective: 800px;
            inset: 0;
            z-index: 200;
            position: absolute;
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            grid-template-rows: repeat(5, 1fr);
            width: 100%;
            height: 100%;
        }
        .tracker {
            position: relative;
            z-index: 200;
            width: 100%;
            height: 100%;
        }
        
        /* CAMBIO DE COLOR: Paleta azul limpia y corporativa */
        .card-3d {
            position: absolute;
            inset: 0;
            z-index: 10;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border-radius: 1rem;
            background: #1e40af; /* Azul sutil y sólido en modo claro */
            border: 1px solid #3b82f6;
            box-shadow: 0 4px 15px -2px rgba(30, 64, 175, 0.2);
            transition: transform 300ms, filter 300ms, box-shadow 300ms;
            color: white;
        }
        
        :global(.dark) .card-3d {
            background: #090f26; /* Integra de forma limpia sobre el fondo global #020618 */
            border: 1px solid #1e293b;
            box-shadow: 0 4px 20px -2px rgba(0,0,0,0.3);
        }
        
        /* El destello de luz sobre la tarjeta al pasar el mouse */
        .container-3d:hover .card-3d::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 0%, rgba(255,255,255,0.15), transparent 70%);
            border-radius: 1rem;
            pointer-events: none;
            z-index: 2;
        }

        /* Matrices de Rotación (Ahora funcionando perfecto junto con AOS) */
        .tr-1:hover ~ .card-3d { transform: rotateX(20deg) rotateY(-10deg); }
        .tr-2:hover ~ .card-3d { transform: rotateX(20deg) rotateY(-5deg); }
        .tr-3:hover ~ .card-3d { transform: rotateX(20deg) rotateY(0deg); }
        .tr-4:hover ~ .card-3d { transform: rotateX(20deg) rotateY(5deg); }
        .tr-5:hover ~ .card-3d { transform: rotateX(20deg) rotateY(10deg); }
        .tr-6:hover ~ .card-3d { transform: rotateX(10deg) rotateY(-10deg); }
        .tr-7:hover ~ .card-3d { transform: rotateX(10deg) rotateY(-5deg); }
        .tr-8:hover ~ .card-3d { transform: rotateX(10deg) rotateY(0deg); }
        .tr-9:hover ~ .card-3d { transform: rotateX(10deg) rotateY(5deg); }
        .tr-10:hover ~ .card-3d { transform: rotateX(10deg) rotateY(10deg); }
        .tr-11:hover ~ .card-3d { transform: rotateX(0deg) rotateY(-10deg); }
        .tr-12:hover ~ .card-3d { transform: rotateX(0deg) rotateY(-5deg); }
        .tr-13:hover ~ .card-3d { transform: rotateX(0deg) rotateY(0deg); }
        .tr-14:hover ~ .card-3d { transform: rotateX(0deg) rotateY(5deg); }
        .tr-15:hover ~ .card-3d { transform: rotateX(0deg) rotateY(10deg); }
        .tr-16:hover ~ .card-3d { transform: rotateX(-10deg) rotateY(-10deg); }
        .tr-17:hover ~ .card-3d { transform: rotateX(-10deg) rotateY(-5deg); }
        .tr-18:hover ~ .card-3d { transform: rotateX(-10deg) rotateY(0deg); }
        .tr-19:hover ~ .card-3d { transform: rotateX(-10deg) rotateY(5deg); }
        .tr-20:hover ~ .card-3d { transform: rotateX(-10deg) rotateY(10deg); }
        .tr-21:hover ~ .card-3d { transform: rotateX(-20deg) rotateY(-10deg); }
        .tr-22:hover ~ .card-3d { transform: rotateX(-20deg) rotateY(-5deg); }
        .tr-23:hover ~ .card-3d { transform: rotateX(-20deg) rotateY(0deg); }
        .tr-24:hover ~ .card-3d { transform: rotateX(-20deg) rotateY(5deg); }
        .tr-25:hover ~ .card-3d { transform: rotateX(-20deg) rotateY(10deg); }

        .tracker:hover ~ .card-3d {
            transition: 125ms ease-in-out;
            filter: brightness(1.1); /* Hace que el color estático brille al pasar el mouse */
            box-shadow: 0 20px 30px -10px rgba(0,0,0,0.4);
        }
        :global(.dark) .tracker:hover ~ .card-3d {
            border-color: #3b82f6; /* El borde se ilumina en azul eléctrico al hover en dark mode */
        }
        .card-3d i {
            margin-bottom: 0.5rem;
            transition: transform 0.2s;
        }
        .tracker:hover ~ .card-3d i { transform: scale(1.1); }
        .card-3d span {
            font-weight: 600;
            font-size: 0.9375rem;
        }
        .noselect { user-select: none; }
    }
    @media (max-width: 1023px) {
        .tarjeta-3d-wrapper { display: none; }
        .tarjeta-simple { display: flex; }
    }
</style>
    </div>
</section>


<!-- ========== SECCIÓN SIETE: CONTACTO (formulario + datos) ========== -->
<section id="contacto" class="bg-white dark:bg-[#020618] py-20 border-t border-gray-100 dark:border-[#0f172a] transition-colors overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div data-aos="fade-up" class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-dark dark:text-white mb-4 transition-colors">
                ¿Necesitás <span class="text-primary">energía solar</span>?
            </h2>
            <p class="text-base text-gray-500 dark:text-gray-400 transition-colors">
                Comunicate con nosotros, te asesoramos sin compromiso
            </p>
        </div>
        
        <!-- Tarjeta del Formulario -->
        <form data-aos="fade-up" data-aos-delay="200" class="space-y-6 bg-slate-50 dark:bg-[#090f26] p-6 md:p-12 rounded-[2rem] shadow-md border border-gray-200 dark:border-slate-800 transition-colors">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Nombre -->
                <div class="space-y-2">
                    <label class="block text-[13px] font-medium text-gray-600 dark:text-gray-400 ml-1">Nombre</label>
                    <input type="text" required placeholder="Tu nombre" class="w-full bg-white dark:bg-[#020618] border border-gray-200 dark:border-slate-700 rounded-xl px-5 py-3.5 text-[14px] text-dark dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                </div>
                <!-- Apellido -->
                <div class="space-y-2">
                    <label class="block text-[13px] font-medium text-gray-600 dark:text-gray-400 ml-1">Apellido</label>
                    <input type="text" required placeholder="Tu apellido" class="w-full bg-white dark:bg-[#020618] border border-gray-200 dark:border-slate-700 rounded-xl px-5 py-3.5 text-[14px] text-dark dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Email -->
                <div class="space-y-2">
                    <label class="block text-[13px] font-medium text-gray-600 dark:text-gray-400 ml-1">Correo electrónico</label>
                    <input type="email" required placeholder="tu@email.com" class="w-full bg-white dark:bg-[#020618] border border-gray-200 dark:border-slate-700 rounded-xl px-5 py-3.5 text-[14px] text-dark dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                </div>
                <!-- WhatsApp -->
                <div class="space-y-2">
                    <label class="block text-[13px] font-medium text-gray-600 dark:text-gray-400 ml-1">Teléfono / WhatsApp</label>
                    <input type="tel" required placeholder="Ej: 2922480475" class="w-full bg-white dark:bg-[#020618] border border-gray-200 dark:border-slate-700 rounded-xl px-5 py-3.5 text-[14px] text-dark dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                </div>
            </div>
            
            <!-- Selector Tipo de Consulta -->
            <div class="space-y-2 relative">
                <label class="block text-[13px] font-medium text-gray-600 dark:text-gray-400 ml-1">Tipo de consulta</label>
                <div class="relative">
                    <select required class="w-full bg-white dark:bg-[#020618] border border-gray-200 dark:border-slate-700 rounded-xl px-5 py-3.5 text-[14px] text-dark dark:text-white outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all appearance-none cursor-pointer pr-12">
                        <option value="" disabled selected class="text-gray-400">Seleccioná una opción</option>
                        <option value="residencial">Residencial</option>
                        <option value="comercial">Comercial / Industrial</option>
                        <option value="rural">Rural</option>
                        <option value="otro">Otro</option>
                    </select>
                    <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
                </div>
            </div>
            
            <!-- Mensaje -->
            <div class="space-y-2">
                <label class="block text-[13px] font-medium text-gray-600 dark:text-gray-400 ml-1">Mensaje</label>
                <textarea rows="4" required placeholder="Contanos tu proyecto o consulta..." class="w-full bg-white dark:bg-[#020618] border border-gray-200 dark:border-slate-700 rounded-xl px-5 py-3.5 text-[14px] text-dark dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all resize-none"></textarea>
            </div>
            
            <!-- Botón de Envío -->
            <div class="text-center pt-2">
                <button type="submit" class="bg-primary text-white px-8 py-3.5 rounded-xl text-[14px] font-semibold hover:bg-opacity-90 flex items-center justify-center gap-2 mx-auto transition-colors shadow-sm">
                    Enviar Consulta <i data-lucide="send" class="w-4 h-4"></i>
                </button>
            </div>
        </form>

        <!-- Bloque de Contacto Directo -->
        <div class="mt-12 text-center">
            <p class="text-gray-500 dark:text-gray-400 text-sm">
                También podés contactarte directamente con <strong class="text-dark dark:text-white">Nicolás Burgos</strong>
            </p>
            <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-8 mt-4">
                <a href="https://wa.me/5492922480475" target="_blank" class="inline-flex items-center gap-2 text-primary hover:underline font-medium transition-all text-[15px]">
                    <i data-lucide="phone" class="w-4 h-4"></i> +54 9 2922 480475
                </a>
                <a href="mailto:nicoburgos4@gmail.com" class="inline-flex items-center gap-2 text-primary hover:underline font-medium transition-all text-[15px]">
                    <i data-lucide="mail" class="w-4 h-4"></i> nicoburgos4@gmail.com
                </a>
            </div>
        </div>
        
    </div>
</section>